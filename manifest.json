{
  "manifest_version": 3,
  "name": "书签检测器",
  "version": "1.0.0",
  "description": "打开任意网页时，自动检测当前页面是否已收藏，并显示所在文件夹路径。",
  "permissions": [
    "bookmarks",
    "tabs",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "书签检测器"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
